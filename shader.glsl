float cross2(vec2 a, vec2 b) {
    return a.x * b.y - a.y * b.x;
}

float sdf_line(vec2 p, vec2 a, vec2 b) {
    vec2 dir = normalize(b - a) * 5e-5;
    a += dir;
    b -= dir;
    vec2 ba = b - a;
    vec2 pa = p - a;
    float h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
    vec2 k = pa - h * ba;
    vec2 n = vec2(ba.y, -ba.x);
    return (dot(k, n) >= 0.0) ? length(k) : -length(k);
}

float sdf_bezier(vec2 pos, vec2 A, vec2 B, vec2 C) {
    vec2 dir = normalize(C - A) * 5e-5;
    A += dir;
    B += dir;
    C -= dir;

    vec2 a = B - A;
    vec2 b = A - 2.0 * B + C;
    vec2 c = a * 2.0;
    vec2 d = A - pos;

    float kk = 1.0 / dot(b, b);
    float kx = kk * dot(a, b);
    float ky = kk * (2.0 * dot(a, a) + dot(d, b)) / 3.0;
    float kz = kk * dot(d, a);

    float p = ky - kx * kx;
    float p3 = p * p * p;
    float q = kx * (2.0 * kx * kx - 3.0 * ky) + kz;
    float h = q * q + 4.0 * p3;

    if(h >= 0.0) {
        h = sqrt(h);
        vec2 x = 0.5 * (vec2(h, -h) - q);
        vec2 uv = sign(x) * pow(abs(x), vec2(1.0 / 3.0));
        float t = clamp(uv.x + uv.y - kx, 0.0, 1.0);
        vec2 q = d + (c + b * t) * t;
        float res = dot(q, q);
        float sgn = cross2(c + 2.0 * b * t, q);
        return sign(sgn) * sqrt(res);
    } else {
        float z = sqrt(-p);
        float v = acos(q / (p * z * 2.0)) / 3.0;
        float m = cos(v);
        float n = sin(v) * 1.73205081;
        vec3 t = clamp(vec3(m + m, -n - m, n - m) * z - kx, 0.0, 1.0);
        vec2 qx = d + (c + b * t.x) * t.x;
        float dx = dot(qx, qx);
        float sx = cross2(c + 2.0 * b * t.x, qx);
        vec2 qy = d + (c + b * t.y) * t.y;
        float dy = dot(qy, qy);
        float sy = cross2(c + 2.0 * b * t.y, qy);
        float res = (dx < dy) ? dx : dy;
        float sgn = (dx < dy) ? sx : sy;
        return sign(sgn) * sqrt(res);
    }
}

float sdf_bezier_approx(vec2 p, vec2 a, vec2 b, vec2 c) {
    vec2 dir = normalize(c - a) * 3e-5;
    a += dir;
    b += dir;
    c -= dir;
    vec2 ab = b - a;
    vec2 d = c - 2.0 * b + a;
    float t = clamp(dot(p - a, ab) / dot(ab, ab), 0.0, 1.0);
    // Newton iters
    for(int i = 0; i < 3; ++i) {
        vec2 q = a + ab * 2.0 * t + d * t * t;
        vec2 dq = ab * 2.0 + d * 2.0 * t;
        float df = dot(dq, dq) + 2.0 * dot(q - p, d);
        t = clamp(t - dot(q - p, dq) / max(df, 1e-5), 0.0, 1.0);
    }
    vec2 q = a + ab * 2.0 * t + d * t * t;
    float dist = length(q - p);
    vec2 dq = ab * 2.0 + d * 2.0 * t;
    float sign = sign(cross2(dq, q - p));
    return sign * dist;
}

void combine(out float d, float sdf) {
    if(abs(sdf) < abs(d))
        d = sdf;
}

